# Server Configuration
PORT=8000
HOST=0.0.0.0
NODE_ENV=development

# Frontend Configuration
VITE_API_URL=http://localhost:8000/api

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/blackbar
MONGODB_DB_NAME=blackbar

# MongoDB credentials (consumed by the mongodb container in docker-compose.yml)
MONGO_USERNAME=blackbar
MONGO_PASSWORD=changeme

# Authentication
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING
# Access-token lifetime, in integer minutes. Default: 60.
JWT_EXPIRATION=60

# Development Mode (NEVER set to true in production!)
DEV_MODE=false

# LLM Configuration
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_API_KEY_ENCRYPTION_KEY=CHANGE_THIS_TO_FERNET_KEY

# Cohere API key (optional - only required if seeding Cohere LLM configs)
COHERE_API_KEY=

# Legacy OpenAI API Configuration (deprecated - use LLM config system)
# OPENAI_API_KEY=your_openai_api_key_here

# Magic Link Rate Limiting (RFC-007)
# For production, use 3 requests per 1 hour. For testing, increase as needed.
MAGIC_LINK_RATE_LIMIT_MAX=3
MAGIC_LINK_RATE_LIMIT_HOURS=1

# Public User Session Duration (RFC-007)
# How long public users stay logged in (in hours). Default: 8 hours.
PUBLIC_USER_SESSION_HOURS=8

# SendGrid Email (RFC-007)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@blackbar.app
SENDGRID_FROM_NAME=Blackbar FOI System

# Document Processing
MAX_UPLOAD_SIZE=20MB
ALLOWED_FILE_TYPES=pdf,docx,eml

# Logging
LOG_LEVEL=info

# Production deployment
# Persistent data directory for docker-compose.prod.yml volumes (mongodb, grafana).
# Defaults to ./data alongside docker-compose.prod.yml if unset.
BLACKBAR_DATA_DIR=./data
